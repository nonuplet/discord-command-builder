{
	"type": "module",
	"scripts": {
		"compile": "pnpm tsc",
		"register": "node --env-file-if-exists=.env dist/main.js --config config.yaml",
		"start": "pnpm compile && pnpm register",
		"dev": "node --loader ts-node/esm --env-file-if-exists=.env src/main.ts --config config.yaml"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"js-yaml": "^4.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.3.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
